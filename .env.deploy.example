# =============================================================================
# Zotero RAG - Deployment Environment File
# =============================================================================
# Usage: node bin/deploy.mjs .env.deploy.myserver
# Copy this file to .env.deploy.<target> and fill in the values.
# DEPLOY_* keys map to container.mjs deploy options; everything else is passed
# as a container environment variable via --env KEY.

# On Debian/Ubuntu, deploy with `sudo env "PATH=$PATH:/usr/sbin:/sbin" node bin/deploy.mjs .env.deploy.example`


# --- Deployment target -------------------------------------------------------

DEPLOY_FQDN=localhost
DEPLOY_TAG=latest
DEPLOY_DATA_DIR=/srv/zotero-rag/data  # always use absolute paths — ~ is expanded by the shell and resolves to root's home when run with sudo
DEPLOY_PORT=8119
# nginx upload limit — increase for large PDFs (default: 300M, nginx units: M / G)
DEPLOY_MAX_BODY_SIZE=1G
# Pull the latest image from the registry instead of building locally (default: false)
DEPLOY_PULL=true
DEPLOY_NO_SSL=true          # skip SSL (HTTP only, false by default)
DEPLOY_NO_NGINX=true        # skip nginx config entirely, false by default
# Re-deploy controls — by default, already-running/configured items are left alone:
# DEPLOY_RESTART_SIDECARS=true   # Restart kreuzberg + qdrant even if already running
# DEPLOY_RECONFIGURE_NGINX=true  # Rewrite nginx config even if already set up
# DEPLOY_RECONFIGURE_SSL=true    # Re-run certbot even if SSL cert already exists
# DEPLOY_CLEAR_LOG=true          # Truncate <DEPLOY_DATA_DIR>/logs/server.log before starting
# Register as systemd Quadlet services (auto-restart, survives reboots; requires sudo):
# DEPLOY_SYSTEMD_SERVICE=zotero-rag
# Share an existing kreuzberg service instead of creating a new one (for multiple instances):
# DEPLOY_SHARED_KREUZBERG=zotero-rag-kreuzberg

# Local model support (sentence-transformers/torch, ~1-2 GB extra):
# Only set this to true when using a local-inference preset (apple-silicon-32gb,
# high-memory, cpu-only). Remote presets (remote-openai, etc.)
# do NOT need this — it is false by default.
# DEPLOY_LOCAL_MODELS=true

# --- Container environment variables -----------------------------------------

# User an OpenAI inference and embedding endpoint here as an example, check the documentation 
# for other presets: https://github.com/cboulanger/zotero-rag/blob/main/docs/presets.md
MODEL_PRESET=remote-openai
OPENAI_API_KEY=sk-... # set a real OpenAI key here
# ANTHROPIC_API_KEY=sk-ant-...
LOG_LEVEL=INFO
# Number of uvicorn worker processes (default: 4). Requires the Qdrant sidecar.
# Set to 1 when running without Qdrant (--no-qdrant / local file mode).
# UVICORN_WORKERS=4

# Automatic (cron) indexing
# Fernet key encrypting the auto-index key store (read-only Zotero API keys that
# users submit via the plugin). Required for the hourly cron indexer and the
# auto-index API endpoints; when unset, both are disabled.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep it stable — rotating it makes all previously stored keys undecryptable.
# AUTOINDEX_SECRET=your_generated_fernet_key

# Access Control (Zotero-key authentication)
# Required whenever DEPLOY_FQDN is a real host rather than localhost: every
# request must present a caller key (X-Zotero-API-Key) that resolves to a
# Zotero identity AND passes one of the checks below. At least one is
# REQUIRED for such deployments — the server refuses to start without it.
# See .env.dist for full details.
#
# NOTE: bin/deploy.mjs auto-sets the container's API_HOST to DEPLOY_FQDN when
# this section applies and API_HOST isn't set below — this is what activates
# the access gate at all. Only set API_HOST explicitly here if it must differ
# from DEPLOY_FQDN (e.g. deploying behind a reverse proxy under a different
# public name).
# API_HOST=zotero-rag.example.com
# AUTHORIZED_GROUP_ID=998877          # Zotero group whose members are authorized
# AUTHORIZED_USER_IDS=39226,123456    # explicit allowlist, comma-separated (OR semantics)

# CORS
# ALLOWED_ORIGINS=https://myhost   # Restrict CORS origins (default: *)
