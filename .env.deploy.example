# =============================================================================
# Zotero RAG - Deployment Environment File
# =============================================================================
# Usage: node bin/deploy.mjs .env.deploy.myserver
# Copy this file to .env.deploy.<target> and fill in the values.
# DEPLOY_* keys map to container.mjs deploy options; everything else is passed
# as a container environment variable via --env KEY.

# NOTE: Docker Hub push credentials (DOCKER_HUB_USERNAME, DOCKER_HUB_TOKEN) are
# NOT set here — they are developer secrets that live in the local .env file and
# are only needed when running `node bin/container.mjs push`.
# This file is for configuring what gets deployed on the target server.

# --- Deployment target -------------------------------------------------------

DEPLOY_FQDN=rag.example.com
DEPLOY_TAG=latest
DEPLOY_DATA_DIR=/srv/zotero-rag/data
DEPLOY_PORT=8119
# Pull the latest image from the registry instead of building locally (default: false)
DEPLOY_PULL=true
# DEPLOY_SSL=false          # uncomment to skip SSL (HTTP only)
# DEPLOY_NGINX=false        # uncomment to skip nginx config entirely

# Local model support (sentence-transformers/torch, ~1-2 GB extra):
# Only set this to true when using a local-inference preset (apple-silicon-32gb,
# high-memory, cpu-only). Remote presets (remote-kisski, remote-openai, etc.)
# do NOT need this — it is false by default.
# DEPLOY_LOCAL_MODELS=true  # include sentence-transformers/torch in the build

# OCR support (Tesseract, included by default):
# Set to false for a smaller image when OCR is not needed.
# DEPLOY_NO_OCR=true        # exclude Tesseract from the build

# --- Container environment variables -----------------------------------------

MODEL_PRESET=remote-openai
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# KISSKI_API_KEY=...
LOG_LEVEL=INFO

# OCR at runtime: only relevant when Tesseract is installed in the image (default).
# Set to false if the image was built with DEPLOY_NO_OCR=true.
# OCR_ENABLED=false

# Remote server mode: plugin uploads documents directly; no local Zotero needed
# REQUIRE_ZOTERO=false

# Security
# API_KEY=your-secret-key          # Require X-API-Key header on all requests
# ALLOWED_ORIGINS=https://myhost   # Restrict CORS origins (default: *)
