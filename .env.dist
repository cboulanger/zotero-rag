# Zotero RAG Backend Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# API Configuration
# =============================================================================

# API server host and port
# API_HOST=localhost
# API_PORT=8119

# =============================================================================
# Model Configuration
# =============================================================================

# Hardware preset to use
# Options: See docs/presets.md
# Default: cpu-only
# Remote presets (remote-kisski, remote-openai) need no local GPU and do NOT
# require sentence-transformers/torch — they are the recommended default.
# Local presets (apple-silicon-32gb, high-memory, cpu-only) require:
#   uv sync --extra local-models   (or Docker build with --local-models flag)
MODEL_PRESET=remote-kisski

# Paths for model weights and vector database
# Default: ~/.cache/zotero-rag/models and ~/.local/share/zotero-rag/qdrant
MODEL_WEIGHTS_PATH=~/.cache/zotero-rag/models
VECTOR_DB_PATH=~/.local/share/zotero-rag/qdrant

# =============================================================================
# Zotero Configuration
# =============================================================================

# Zotero local API URL
# Note: Use port 23124 to match zotero-plugin-scaffold default during development, but this can be changed if needed. Make sure to update the plugin configuration accordingly.
# The scaffold's preference override isn't working (as of 2026-01)
# ZOTERO_API_URL=http://localhost:23119

# =============================================================================
# Logging Configuration
# =============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# Log file path
# Default: ~/.local/share/zotero-rag/logs/server.log
LOG_FILE=~/.local/share/zotero-rag/logs/server.log

# Document extraction backend.
#   kreuzberg (default) — supports 91+ formats, OCR, DOCX, EPUB, etc.
#                         Requires Docker or Podman to run the kreuzberg sidecar.
#                         npm start / server:start manages the sidecar automatically.
#   legacy              — original pypdf + spaCy pipeline; PDF only, no OCR.
#                         No container runtime required; works everywhere.
# EXTRACTOR_BACKEND=kreuzberg

# URL of the kreuzberg document extraction sidecar.
# When running via docker-compose or container.mjs, this is set automatically.
# For local development (no Docker/Podman), either:
#   a) set EXTRACTOR_BACKEND=legacy  (no container needed)
#   b) start kreuzberg manually: docker run -p 8100:8100 ghcr.io/kreuzberg-dev/kreuzberg:latest
# KREUZBERG_URL=http://localhost:8100

# =============================================================================
# API Keys (for remote inference and model downloads)
# =============================================================================

# HuggingFace token for downloading models (required for some models like nomic-embed-text-v1.5)
# Get your token at: https://huggingface.co/settings/tokens
# HF_TOKEN=your_huggingface_token_here

# OpenAI API key (for remote-openai preset or remote embeddings)
# OPENAI_API_KEY=sk-...

# Anthropic API key (for Claude models)
# ANTHROPIC_API_KEY=sk-ant-...

# Cohere API key (for Cohere embeddings/models)
# COHERE_API_KEY=...

# GWDG KISSKI Academic Cloud LLM service (for remote-kisski preset)
# Get access at: https://kisski.gwdg.de/
# KISSKI_API_KEY=your_kisski_api_key

# =============================================================================
# Container Registry (for building and pushing Docker images)
# =============================================================================

# Image used by docker-compose (default: cboulanger/zotero-rag:latest)
# Override to select a specific architecture tag when multi-arch manifests are not used:
#   ZOTERO_RAG_IMAGE=cboulanger/zotero-rag:latest-amd64
#   ZOTERO_RAG_IMAGE=cboulanger/zotero-rag:latest-arm64
# ZOTERO_RAG_IMAGE=cboulanger/zotero-rag:latest

# Docker Hub credentials for `node bin/container.mjs push`
# Create a Personal Access Token at: https://hub.docker.com/settings/security
# DOCKER_HUB_USERNAME=cboulanger
# DOCKER_HUB_TOKEN=your_docker_hub_token

# =============================================================================
# Development Configuration (only useful for developing the Zotero plugin)
# =============================================================================

# Path to the Zotero binary file.
# For macOS, the path is typically `*/Zotero.app/Contents/MacOS/zotero`.
# ZOTERO_PLUGIN_ZOTERO_BIN_PATH=/path/to/zotero.exe

# Path to the profile used for development.
# To create a profile for development, start the profile manager with `/path/to/zotero.exe -p`.
# More info: https://www.zotero.org/support/kb/profile_directory
# ZOTERO_PLUGIN_PROFILE_PATH=/path/to/profile

# Optional path to the data directory (if needed).
# ZOTERO_PLUGIN_DATA_DIR=/path/to/data