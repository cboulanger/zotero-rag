# Zotero RAG Backend Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# API Configuration
# =============================================================================

# API server host and port
# API_HOST=localhost
# API_PORT=8119

# =============================================================================
# Model Configuration
# =============================================================================

# Hardware preset to use
# Options: See docs/presets.md
# Default: cpu-only
# Remote presets (remote-kisski, remote-openai) need no local GPU and do NOT
# require sentence-transformers/torch — they are the recommended default.
# Local presets (apple-silicon-32gb, high-memory, cpu-only) require:
#   uv sync --extra local-models   (or Docker build with --local-models flag)
MODEL_PRESET=remote-kisski

# =============================================================================
# Data Storage
# =============================================================================

# Base directory for all persistent data (models, vector DB, logs, system).
# Defaults to <project_root>/data.
# DATA_PATH=./data

# Override individual subdirectories (optional; each defaults to <DATA_PATH>/<subdir>):
# MODEL_WEIGHTS_PATH=<DATA_PATH>/models
# VECTOR_DB_PATH=<DATA_PATH>/qdrant
# LOG_FILE=<DATA_PATH>/logs/server.log

# =============================================================================
# Logging Configuration
# =============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# =============================================================================
# Access Control (Zotero-key authentication)
# =============================================================================

# Loopback deployments (API_HOST unset or localhost/127.0.0.1) need none of
# this: there is exactly one trusted local user and no Zotero-key auth is
# required at all.
#
# Every other deployment authenticates each request with the caller's own
# read-only Zotero API key (sent by the plugin as X-Zotero-API-Key) and then
# checks it against an access gate below — a valid Zotero key alone is NOT
# enough, since any Zotero.org account could otherwise use your server.
# At least one of AUTHORIZED_GROUP_ID / AUTHORIZED_USER_IDS is REQUIRED for a
# non-loopback deployment; the server refuses to start without one.

# Zotero group ID that gates access. A caller is authorized if their key
# grants read access to this group (i.e. they are a member of it). Manage
# membership entirely on zotero.org — no redeploy needed to add/remove users.
# AUTHORIZED_GROUP_ID=998877

# Explicit allowlist of Zotero user IDs, in addition to AUTHORIZED_GROUP_ID
# (OR semantics). Comma-separated. Useful as a fallback or for a small fixed
# team without a dedicated Zotero group.
# AUTHORIZED_USER_IDS=39226,123456

# Document extraction backend.
#   kreuzberg (default) — supports 91+ formats, OCR, DOCX, EPUB, etc.
#                         Requires Docker or Podman to run the kreuzberg sidecar.
#                         npm start / server:start manages the sidecar automatically.
#   legacy              — original pypdf + spaCy pipeline; PDF only, no OCR.
#                         No container runtime required; works everywhere.
# EXTRACTOR_BACKEND=kreuzberg

# Number of uvicorn worker processes (default: 4 when using the Qdrant sidecar).
# Requires QDRANT_URL to be set — local embedded Qdrant file mode supports only 1 worker.
# UVICORN_WORKERS=4

# Qdrant vector database server URL. When set, uses Qdrant server mode (supports multiple workers).
# When unset, uses local embedded file mode (single worker only).
# QDRANT_URL=http://localhost:6333

# URL of the kreuzberg document extraction sidecar.
# When running via docker-compose or container.mjs, this is set automatically.
# For local development (no Docker/Podman), either:
#   a) set EXTRACTOR_BACKEND=legacy  (no container needed)
#   b) start kreuzberg manually: docker run -p 8100:8100 ghcr.io/kreuzberg-dev/kreuzberg:latest
# KREUZBERG_URL=http://localhost:8100

# Per-request timeout (seconds) for the kreuzberg sidecar.
# Large HTML snapshots and OCR-heavy PDFs may exceed the old 120s default.
# KREUZBERG_TIMEOUT_SECONDS=300

# PDF splitting — large scanned PDFs are split into parts before being sent to kreuzberg
# to prevent the sidecar container from being OOM-killed.
# Accepts human-readable sizes ("50MB", "1GB") or raw byte counts.
# PDF_SPLIT_THRESHOLD=50MB
# PDF_SPLIT_TARGET_PART_SIZE=30MB

# =============================================================================
# API Keys
# =============================================================================

# The preference is that all service API keys are configured and stored on the client 
# so that embedding or inference costs are billed to the actual key owner rather than the 
# server operator. But see https://github.com/cboulanger/zotero-rag/issues/42

# HuggingFace token for downloading models (only required for local models like nomic-embed-text-v1.5)
# Get your token at: https://huggingface.co/settings/tokens
# HF_TOKEN=your_huggingface_token_here

# =============================================================================
# Container Registry (for building and pushing Docker images)
# =============================================================================

# Image used by docker-compose (default: cboulanger/zotero-rag:latest)
# Override to select a specific architecture tag when multi-arch manifests are not used:
#   ZOTERO_RAG_IMAGE=cboulanger/zotero-rag:latest-amd64
#   ZOTERO_RAG_IMAGE=cboulanger/zotero-rag:latest-arm64
# ZOTERO_RAG_IMAGE=cboulanger/zotero-rag:latest

# Docker Hub credentials for `node bin/container.mjs push`
# Create a Personal Access Token at: https://hub.docker.com/settings/security
# DOCKER_HUB_USERNAME=cboulanger
# DOCKER_HUB_TOKEN=your_docker_hub_token

# =============================================================================
# Public Web UI (optional)
# =============================================================================

# Path to a JSON file that whitelists Zotero library slugs for unauthenticated
# RAG queries via the browser UI at /public/.
# Format: { "users/{userId}": { "title": "...", "description": "..." }, "groups/{groupId}": { ... } }
# Only libraries with public Zotero visibility should be listed here.
# When unset, the /public/ UI is disabled (returns empty index).
# In container deployments, place the file in DATA_DIR and point to its /data path:
# PUBLIC_LIBRARIES_CONFIG=/data/public-libraries.json

# =============================================================================
# Zotero API Key (backend scripts only)
# =============================================================================

# Personal API key for api.zotero.org, used only by scripts/openalex_import.py
# to create items and upload PDF attachments — it must have write access to
# the target group library. Create one at: https://www.zotero.org/settings/keys
#
# Not required for anything else: the server itself, cron indexing
# (bin/index_libraries.py), and the plugin all authenticate with per-user
# read-only keys instead (see "Access Control" above and "Automatic (cron)
# Indexing" below).
#
# ZOTERO_API_KEY=your_zotero_api_key


# =============================================================================
# Automatic (cron) Indexing
# =============================================================================

# Fernet symmetric key used to encrypt/decrypt the auto-index key store at
# <DATA_DIR>/system/autoindex_keys.json. Read-only Zotero API keys submitted by
# users via the plugin (Preferences -> Automatic indexing) or with
# `uv run python bin/autoindex_add_key.py <read-only-key>` are stored encrypted
# under this secret, and the hourly cron indexer decrypts them to find libraries
# to index.
#
# When unset, the auto-indexing feature is disabled: the cron indexer exits
# immediately ("no keys can be decrypted") and the auto-index API endpoints
# return 503.
#
# Generate a new secret with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Keep this value stable — rotating it makes all previously stored keys
# undecryptable.
#
# AUTOINDEX_SECRET=your_generated_fernet_key

# Built-in scheduler: if set, the backend indexes automatically every N minutes
# instead of requiring an external cron job. Recommended: 60 (hourly).
# AUTOINDEX_INTERVAL_MINUTES=60

# =============================================================================
# Indexing Performance / Memory Tuning
# =============================================================================

# Number of items processed per subprocess batch during full library sync.
# Each batch runs in a fresh OS process; when it exits all memory is freed.
# Lower values reduce peak RSS but increase subprocess-spawn overhead.
# Set to 0 to disable subprocess isolation (runs inline; not recommended in production).
# Default: 300
#INDEX_BATCH_SIZE=300

# Maximum number of texts sent per embedding API call.
# Lower values reduce peak RSS when indexing large documents (fewer texts held in
# memory simultaneously) at the cost of more round-trips to the embedding service.
# The remote-kisski preset defaults to 256; for the current 16 GB host, 64 is safer.
# Default: 256 (remote-kisski preset value)
#EMBEDDING_BATCH_SIZE=64

# =============================================================================
# OpenAlex Import Script (scripts/openalex_import.py)
# =============================================================================

# Your email address for OpenAlex "polite pool" requests.
# Including your email gives you a higher rate limit (no auth required).
# See: https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
# OPENALEX_EMAIL=you@example.com

# =============================================================================
# Development Configuration (only useful for developing the Zotero plugin)
# =============================================================================

# Path to the Zotero binary file.
# For macOS, the path is typically `*/Zotero.app/Contents/MacOS/zotero`.
# ZOTERO_PLUGIN_ZOTERO_BIN_PATH=/path/to/zotero.exe

# Path to the profile used for development.
# To create a profile for development, start the profile manager with `/path/to/zotero.exe -p`.
# More info: https://www.zotero.org/support/kb/profile_directory
# ZOTERO_PLUGIN_PROFILE_PATH=/path/to/profile

# Optional path to the data directory (if needed).
# ZOTERO_PLUGIN_DATA_DIR=/path/to/data